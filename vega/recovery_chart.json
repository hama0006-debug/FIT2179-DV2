{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 1050,
  "height": 430,
  "title": "Monthly International Arrivals to Malaysia, 2020–2024",
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "aggregate": [
        {"op": "sum", "field": "arrivals", "as": "total_arrivals"}
      ],
      "groupby": ["date"]
    }
  ],
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true,
    "color": "#2f5f93",
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "title": "Month"
    },
    "y": {
      "field": "total_arrivals",
      "type": "quantitative",
      "title": "Total arrivals"
    },
    "tooltip": [
      {"field": "date", "type": "temporal", "title": "Month"},
      {"field": "total_arrivals", "type": "quantitative", "title": "Arrivals", "format": ","}
    ]
  }
}
