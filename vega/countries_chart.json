{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 420,
  "height": 360,
  "title": "Top 15 Visitor Source Countries",
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "arrivals",
          "as": "total_arrivals"
        }
      ],
      "groupby": ["country"]
    },
    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "sort": [
        {
          "field": "total_arrivals",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.rank <= 15"
    }
  ],
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": "-x",
      "title": "Country"
    },
    "x": {
      "field": "total_arrivals",
      "type": "quantitative",
      "title": "Total arrivals"
    },
    "color": {
      "value": "#1f6f5f"
    }
  }
}
