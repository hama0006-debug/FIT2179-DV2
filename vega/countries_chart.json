{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 570,
  "height": 390,
  "title": "Top 15 Visitor Source Countries",
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "aggregate": [
        {"op": "sum", "field": "arrivals", "as": "total_arrivals"}
      ],
      "groupby": ["country"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "total_arrivals", "order": "descending"}]
    },
    {"filter": "datum.rank <= 15"}
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4,
    "tooltip": true
  },
  "encoding": {
    "y": {
      "field": "country",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "total_arrivals",
      "type": "quantitative",
      "title": "Total arrivals"
    },
    "color": {
      "field": "country",
      "type": "nominal",
      "legend": null,
      "scale": {
        "range": [
          "#1f6f5f",
          "#2f8f83",
          "#f6c85f",
          "#e07a5f",
          "#3d5a80",
          "#81b29a",
          "#bc6c25",
          "#6d597a",
          "#457b9d",
          "#a7c957",
          "#8d99ae",
          "#b56576",
          "#2a9d8f",
          "#e9c46a",
          "#264653"
        ]
      }
    },
    "tooltip": [
      {"field": "country", "type": "nominal", "title": "Country"},
      {"field": "total_arrivals", "type": "quantitative", "title": "Total arrivals", "format": ","}
    ]
  }
}
