{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 320,
  "title": "Share of Arrivals Among Top Source Countries",
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "aggregate": [
        {"op": "sum", "field": "arrivals", "as": "total_arrivals"}
      ],
      "groupby": ["country"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "total_arrivals", "order": "descending"}]
    },
    {"filter": "datum.rank <= 10"}
  ],
  "mark": {
    "type": "arc",
    "innerRadius": 70,
    "outerRadius": 145,
    "tooltip": true
  },
  "encoding": {
    "theta": {
      "field": "total_arrivals",
      "type": "quantitative"
    },
    "color": {
      "field": "country",
      "type": "nominal",
      "title": "Country",
      "scale": {
        "range": [
          "#1f6f5f",
          "#2f8f83",
          "#f6c85f",
          "#e07a5f",
          "#3d5a80",
          "#81b29a",
          "#bc6c25",
          "#6d597a",
          "#457b9d",
          "#a7c957"
        ]
      }
    },
    "tooltip": [
      {"field": "country", "type": "nominal", "title": "Country"},
      {"field": "total_arrivals", "type": "quantitative", "title": "Total arrivals", "format": ","}
    ]
  }
}
