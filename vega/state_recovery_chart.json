{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 330,
  "title": {
    "text": "State Recovery Race",
    "subtitle": "Annual arrivals for the leading state entry markets",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "color": "#123c3c",
    "subtitleColor": "#5f6b75"
  },
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "calculate": "year(datum.date)",
      "as": "year"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "arrivals",
          "as": "annual_arrivals"
        }
      ],
      "groupby": ["year", "soe"]
    },
    {
      "joinaggregate": [
        {
          "op": "sum",
          "field": "annual_arrivals",
          "as": "state_total"
        }
      ],
      "groupby": ["soe"]
    },
    {
      "window": [
        {
          "op": "dense_rank",
          "as": "state_rank"
        }
      ],
      "sort": [
        {
          "field": "state_total",
          "order": "descending"
        }
      ]
    },
    {
      "filter": "datum.state_rank <= 5"
    }
  ],
  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 70
    },
    "strokeWidth": 3,
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelAngle": 0,
        "labelFontSize": 11
      }
    },
    "y": {
      "field": "annual_arrivals",
      "type": "quantitative",
      "title": "Annual arrivals",
      "axis": {
        "format": "s",
        "labelFontSize": 11
      }
    },
    "color": {
      "field": "soe",
      "type": "nominal",
      "title": "State",
      "scale": {
        "range": ["#123c3c", "#2f8f83", "#f6c85f", "#e07a5f", "#3d5a80"]
      },
      "legend": {
        "orient": "bottom",
        "columns": 3
      }
    },
    "tooltip": [
      {
        "field": "soe",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "annual_arrivals",
        "type": "quantitative",
        "title": "Arrivals",
        "format": ","
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelColor": "#24323d",
      "titleColor": "#123c3c",
      "gridColor": "#e2e8e4"
    },
    "legend": {
      "labelColor": "#24323d",
      "titleColor": "#123c3c"
    }
  }
}
