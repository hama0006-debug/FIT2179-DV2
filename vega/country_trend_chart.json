{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 390,
  "height": 320,
  "title": "Recovery Patterns of Major Visitor Markets",
  "data": {"url": "data/arrivals_soe.csv"},
  "transform": [
    {"filter": "indexof(['SGP','IDN','THA','CHN','BRN','IND'], datum.country) >= 0"},
    {
      "aggregate": [{"op": "sum", "field": "arrivals", "as": "monthly_arrivals"}],
      "groupby": ["date", "country"]
    }
  ],
  "mark": {"type": "line", "strokeWidth": 2.5, "tooltip": true},
  "encoding": {
    "x": {"field": "date", "type": "temporal", "title": "Month"},
    "y": {"field": "monthly_arrivals", "type": "quantitative", "title": "Monthly arrivals"},
    "color": {
      "field": "country",
      "type": "nominal",
      "title": "Country",
      "scale": {"range": ["#123c3c", "#e07a5f", "#2f8f83", "#3d5a80", "#f6c85f", "#bc6c25"]}
    },
    "tooltip": [
      {"field": "country", "type": "nominal", "title": "Country"},
      {"field": "date", "type": "temporal", "title": "Month"},
      {"field": "monthly_arrivals", "type": "quantitative", "title": "Arrivals", "format": ","}
    ]
  }
}
