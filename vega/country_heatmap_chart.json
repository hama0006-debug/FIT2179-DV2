{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 320,
  "title": "Visitor Strength by Country and Year",
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "filter": "indexof(['SGP','IDN','THA','CHN','BRN','IND','PHL','BGD','KOR','AUS'], datum.country) >= 0"
    },
    {
      "aggregate": [
        {"op": "sum", "field": "arrivals", "as": "yearly_arrivals"}
      ],
      "groupby": ["country", "date"]
    }
  ],
  "mark": {
    "type": "rect",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "timeUnit": "year",
      "title": "Year"
    },
    "y": {
      "field": "country",
      "type": "nominal",
      "title": "Country"
    },
    "color": {
      "field": "yearly_arrivals",
      "type": "quantitative",
      "title": "Arrivals",
      "scale": {
        "scheme": "tealblues"
      }
    },
    "tooltip": [
      {"field": "country", "type": "nominal", "title": "Country"},
      {"field": "date", "type": "temporal", "timeUnit": "year", "title": "Year"},
      {"field": "yearly_arrivals", "type": "quantitative", "title": "Arrivals", "format": ","}
    ]
  }
}
