{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 430,
  "height": 320,
  "title": "Visitor Strength by Country and Year",
  "data": {
    "url": "data/arrivals_soe.csv"
  },
  "transform": [
    {
      "filter": "indexof(['SGP','IDN','THA','CHN','BRN','IND','PHL','BGD','KOR','AUS'], datum.country) >= 0"
    },
    {
      "timeUnit": "year",
      "field": "date",
      "as": "year"
    },
    {
      "aggregate": [
        {"op": "sum", "field": "arrivals", "as": "yearly_arrivals"}
      ],
      "groupby": ["country", "year"]
    }
  ],
  "mark": {
    "type": "rect",
    "tooltip": true,
    "cornerRadius": 3
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year"
    },
    "y": {
      "field": "country",
      "type": "nominal",
      "title": null,
      "sort": ["SGP", "IDN", "THA", "CHN", "BRN", "IND", "PHL", "BGD", "KOR", "AUS"]
    },
    "color": {
      "field": "yearly_arrivals",
      "type": "quantitative",
      "title": "Arrivals",
      "scale": {
        "range": ["#f7f3ea", "#d7eadf", "#8fc8b6", "#2f8f83", "#123c3c"]
      }
    },
    "tooltip": [
      {"field": "country", "type": "nominal", "title": "Country"},
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "yearly_arrivals", "type": "quantitative", "title": "Arrivals", "format": ","}
    ]
  }
}
