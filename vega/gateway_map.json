{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "background": "#ffffff",
  "width": 1050,
  "height": 620,
  "title": {
    "text": "Malaysia’s International Tourism Gateways",
    "subtitle": "Entry points sized by total arrivals and coloured by gateway type",
    "fontSize": 22,
    "subtitleFontSize": 14,
    "anchor": "middle",
    "color": "#123c3c",
    "subtitleColor": "#52616b"
  },
  "projection": {
    "type": "mercator",
    "center": [109.3, 4.2],
    "scale": 2300
  },
  "layer": [
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {
          "type": "topojson",
          "feature": "countries"
        }
      },
      "transform": [
        {"filter": "datum.id == 458"}
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#e5f1ed",
        "stroke": "#1f6f5f",
        "strokeWidth": 1.6
      }
    },
    {
      "data": {
        "url": "data/foreign_arrivals.csv"
      },
      "transform": [
        {
          "aggregate": [
            {"op": "sum", "field": "arrivals", "as": "total_arrivals"}
          ],
          "groupby": ["poe"]
        },
        {
          "lookup": "poe",
          "from": {
            "data": {"url": "data/poe.csv"},
            "key": "poe",
            "fields": ["lat", "long", "type", "state"]
          }
        },
        {"filter": "isValid(datum.lat) && isValid(datum.long)"}
      ],
      "mark": {
        "type": "circle",
        "opacity": 0.72,
        "stroke": "#ffffff",
        "strokeWidth": 1.8,
        "tooltip": true
      },
      "encoding": {
        "longitude": {"field": "long", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "total_arrivals",
          "type": "quantitative",
          "title": "Arrival volume",
          "scale": {"range": [35, 1300]},
          "legend": {
            "orient": "right",
            "titleFontSize": 13,
            "labelFontSize": 12
          }
        },
        "color": {
          "field": "type",
          "type": "nominal",
          "title": "Gateway type",
          "scale": {
            "domain": ["Air", "Land", "Sea"],
            "range": ["#2f8f83", "#f6c85f", "#e07a5f"]
          },
          "legend": {
            "orient": "right",
            "titleFontSize": 13,
            "labelFontSize": 12,
            "symbolSize": 130
          }
        },
        "tooltip": [
          {"field": "poe", "type": "nominal", "title": "Point of entry"},
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "type", "type": "nominal", "title": "Gateway type"},
          {"field": "total_arrivals", "type": "quantitative", "title": "Total arrivals", "format": ","}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "legend": {
      "labelColor": "#24323d",
      "titleColor": "#123c3c"
    }
  }
}
